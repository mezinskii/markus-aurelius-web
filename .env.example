# Public site origin used for canonical URLs, hreflang, sitemap, OG/JSON-LD.
# No trailing slash. Override per environment if needed.
PUBLIC_SITE_URL=https://readaurelius.org

# Sanity (already used by src/lib/sanity.ts)
SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# MailerLite (used by src/pages/api/subscribe.ts)
# Generate at MailerLite → Integrations → Developer API → Generate new token
MAILERLITE_API_KEY=
# Group IDs for the EN and RU subscriber lists.
# Find via MailerLite → Subscribers → Groups → click group → ID in URL.
MAILERLITE_GROUP_ID_EN=
MAILERLITE_GROUP_ID_RU=
