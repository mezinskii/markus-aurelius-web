---
import Layout from '../../layouts/Layout.astro';
import Shell from '../../components/Shell';
import T from '../../components/T.astro';
import { getFrontoLettersIndex } from '../../lib/sanity';
import { romanize } from '../../lib/ui';

const letters = await getFrontoLettersIndex();

function stripFn(text: string) {
  return text.replace(/\{\{fn:\d+\}\}/g, '').replace(/\[\d+\]/g, '');
}
---
<Layout title="Letters — Fronto & Marcus Aurelius">
  <Shell route="fronto" client:load>
    <main class="wrap">

      {/* Page header */}
      <div class="crumbs">
        <a href="/"><T en="Read" ru="Читать" /></a>
        <span class="sep">/</span>
        <span><T en="Letters" ru="Письма" /></span>
      </div>

      <div class="book-head" style="grid-template-columns:auto 1fr">
        <div class="book-head-num" style="font-size:clamp(48px,7vw,120px)">CLIII</div>
        <div class="book-head-meta">
          <div class="book-head-eyebrow">
            <span data-i18n="en">Marcus Aurelius & Fronto · c. 138–166 CE</span>
            <span data-i18n="ru">Марк Аврелий и Фронтон · ок. 138–166 гг.</span>
          </div>
          <h1 class="book-head-title">
            <span data-i18n="en">The <em>Letters</em></span>
            <span data-i18n="ru">Переписка с <em>Фронтоном</em></span>
          </h1>
          <p class="book-head-note">
            <span data-i18n="en">211 letters and fragments between the emperor and his rhetoric teacher — warm, learned,
            sometimes playful. C. R. Haines translation (Loeb Classical Library, 1919).</span>
            <span data-i18n="ru">211 письмем между императором и его учителем риторики — тёплые, учёные,
            порой игривые. Перевод К. Р. Хайнса (Loeb Classical Library, 1919). Русского перевода пока нет —
            тексты ниже на английском.</span>
          </p>
        </div>
      </div>

      {/* Meta strip */}
      <div class="home-meta" style="margin-bottom:56px;padding-top:24px;border-top:1px solid var(--rule)">
        <div>
          <T en="Work" ru="Произведение" /><strong>Epistulae</strong>
        </div>
        <div>
          <T en="Letters" ru="Писем" />
          <strong>
            <span data-i18n="en">211 letters</span>
            <span data-i18n="ru">211 писем</span>
          </strong>
        </div>
        <div>
          <T en="Language" ru="Язык" />
          <strong>
            <span data-i18n="en">Latin</span>
            <span data-i18n="ru">Латинский</span>
          </strong>
        </div>
        <div>
          <T en="Translator" ru="Переводчик" />
          <strong>
            <span data-i18n="en">C. R. Haines, 1919</span>
            <span data-i18n="ru">К. Р. Хайнс, 1919</span>
          </strong>
        </div>
      </div>

      {/* About the correspondence */}
      <div style="max-width:var(--measure);margin-bottom:56px">
        <p style="font-family:var(--serif);font-size:17px;line-height:1.65;color:var(--text-soft);margin:0 0 1em">
          <span data-i18n="en">Marcus Aurelius studied under Marcus Cornelius Fronto from about 138 CE, when he was
          seventeen, until Fronto's death around 166. Their letters — mostly preserved in a palimpsest
          rediscovered in the Vatican and Milan libraries in 1815 — show a side of Marcus absent from
          the <em>Meditations</em>: playful, affectionate, eager to please his teacher.</span>
          <span data-i18n="ru">Марк Аврелий учился у Марка Корнелия Фронтона примерно с 138 года, когда ему было
          семнадцать, до смерти Фронтона около 166 года. Их письма — большей частью сохранившиеся в палимпсесте,
          вновь обнаруженном в библиотеках Ватикана и Милана в 1815 году, — показывают сторону Марка, отсутствующую
          в <em>Размышлениях</em>: игривую, нежную, желающую угодить учителю.</span>
        </p>
        <p style="font-family:var(--serif);font-size:17px;line-height:1.65;color:var(--text-soft);margin:0">
          <span data-i18n="en">The letters survive in fragments, sometimes with lacunae. Haines's Loeb edition fills gaps
          with Latin and prints the Greek passages transliterated. What remains is intimate: master and
          pupil debating rhetoric, exchanging gossip, worrying about each other's health.</span>
          <span data-i18n="ru">Письма сохранились во фрагментах, порой с лакунами. Издание Хайнса в серии Loeb заполняет
          пробелы латынью и приводит греческие пассажи в транслитерации. То, что осталось, — это интимная переписка:
          учитель и ученик обсуждают риторику, обмениваются сплетнями, беспокоятся о здоровье друг друга.</span>
        </p>
      </div>

      {/* Letter list */}
      <div class="books-section-head">
        <h2>
          <span data-i18n="en">All {letters.length} letters <em style="font-size:18px;margin-left:10px">in order</em></span>
          <span data-i18n="ru">Все {letters.length} писем <em style="font-size:18px;margin-left:10px">по порядку</em></span>
        </h2>
      </div>

      <div class="passages">
        {letters.map(l => (
          <a href={`/fronto/${l.letter}`} class="passage-row">
            <div class="passage-row-ref" style="min-width:100px">
              <span data-i18n="en">Letter {romanize(l.letter)}</span>
              <span data-i18n="ru">Письмо {romanize(l.letter)}</span>
            </div>
            <div>
              <div style="font-family:var(--mono);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--text-mute);margin-bottom:4px">
                {l.sender ?? '—'}
                {l.addressee ? <> → {l.addressee}</> : ''}
              </div>
              <p class="passage-row-text">{stripFn(l.preview)}</p>
            </div>
            <span class="passage-row-arrow">→</span>
          </a>
        ))}
      </div>
    </main>
  </Shell>
</Layout>
