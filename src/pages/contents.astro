---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell';
import T from '../components/T.astro';
import { BOOK_META, romanize } from '../lib/ui';
---
<Layout title="Contents — Meditations">
  <Shell route="contents" client:load>
    <main class="wrap">
      <div class="crumbs">
        <a href="/"><T en="Read" ru="Читать" /></a>
        <span class="sep">/</span>
        <span><T en="Contents" ru="Оглавление" /></span>
      </div>

      <div class="book-head">
        <div class="book-head-num">XII</div>
        <div class="book-head-meta">
          <div class="book-head-eyebrow">
            <span data-i18n="en">Marcus Aurelius · 121–180 CE · written in Greek</span>
            <span data-i18n="ru">Марк Аврелий · 121–180 гг. · на греческом</span>
          </div>
          <h1 class="book-head-title">
            <span data-i18n="en">The twelve books <em>— 487 passages</em></span>
            <span data-i18n="ru">Двенадцать книг <em>— 487 пассажей</em></span>
          </h1>
          <p class="book-head-note">
            <span data-i18n="en">Each book is a standalone notebook. Read them in order, or open whichever chapter calls
            to you today — there is no prescribed path.</span>
            <span data-i18n="ru">Каждая книга — отдельная записная тетрадь. Читайте по порядку или открывайте ту главу,
            которая зовёт вас сегодня, — обязательного пути здесь нет.</span>
          </p>
        </div>
      </div>

      <div class="books-grid">
        {BOOK_META.map(b => (
          <a href={`/book/${b.n}`} class="book-tile">
            <div class="book-tile-num">{romanize(b.n)}</div>
            <div class="book-tile-label"><T en="Book" ru="Книга" /> {b.n}</div>
            <p class="book-tile-quote">
              <span data-i18n="en">«{b.quote.en}»</span>
              <span data-i18n="ru">«{b.quote.ru}»</span>
            </p>
            <div class="book-tile-count">
              {b.count} <T en="passages" ru="пассажей" />
            </div>
          </a>
        ))}
      </div>
    </main>
  </Shell>
</Layout>
