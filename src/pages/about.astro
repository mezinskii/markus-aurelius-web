---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell';
import { getFrontoLetterNumbers } from '../lib/sanity';

const letterCount = (await getFrontoLetterNumbers()).length;
---
<Layout title="About — Meditations">
  <Shell route="about" client:load>
    <main class="wrap">
      <div class="crumbs">
        <a href="/">Read</a>
        <span class="sep">/</span>
        <span>About</span>
      </div>

      <section class="about-hero">
        <div class="about-portrait">
          <img src="/markus.png" alt="Marcus Aurelius — Roman marble bust" />
        </div>
        <div class="about-bio">
          <div class="eyebrow" style="margin-bottom:18px">Marcus Aurelius · 121–180 CE · written in Greek</div>
          <h1 class="about-bio-head">
            A quiet reader <em>for a restless book.</em>
          </h1>
          <p>
            Marcus Aurelius wrote the Meditations in private, for himself, as a soldier and emperor.
            It was never meant for publication. It survived anyway — by manuscript, then by press,
            then by translation.
          </p>
          <p>
            This site publishes all twelve books in the public-domain George Long translation,
            indexed, searchable, and linkable by passage. No commentary. No feeds. No login.
          </p>
          <p>
            The <a href="/fronto" style="color:var(--ochre-deep);border-bottom:1px solid currentColor">Letters to Fronto</a>
            section adds {letterCount} surviving letters between Marcus and his rhetoric teacher,
            in C. R. Haines's Loeb translation.
          </p>
        </div>
      </section>

      <section class="about-grid">
        <div class="about-cell">
          <div class="eyebrow">01</div>
          <h3>Everything</h3>
          <p>All 487 passages of the Meditations, plus {letterCount} letters of the Fronto correspondence. George Long and C. R. Haines translations.</p>
        </div>
        <div class="about-cell">
          <div class="eyebrow">02</div>
          <h3>Permalink</h3>
          <p>Every passage has its own URL. Cite, share, or quote without losing the reference.</p>
        </div>
        <div class="about-cell">
          <div class="eyebrow">03</div>
          <h3>Public domain</h3>
          <p>Every translation here is in the public domain. You can reuse them freely.</p>
        </div>
      </section>

      <section class="about-translators">
        <div class="transl-col">
          <h4>Meditations translator</h4>
          <div class="transl-entry">
            <span class="name">George Long</span>
            <span class="yr">1862 · public domain</span>
          </div>
        </div>
        <div class="transl-col">
          <h4>Letters translator</h4>
          <div class="transl-entry">
            <span class="name">C. R. Haines</span>
            <span class="yr">1919 · public domain</span>
          </div>
        </div>
      </section>
    </main>
  </Shell>
</Layout>
