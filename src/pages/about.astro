---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell';
import T from '../components/T.astro';
import { getFrontoLetterNumbers } from '../lib/sanity';

const letterCount = (await getFrontoLetterNumbers()).length;
---
<Layout title="About — Meditations">
  <Shell route="about" client:load>
    <main class="wrap">
      <div class="crumbs">
        <a href="/"><T en="Read" ru="Читать" /></a>
        <span class="sep">/</span>
        <span><T en="About" ru="О книге" /></span>
      </div>

      <section class="about-hero">
        <div class="about-portrait">
          <img src="/markus.png" alt="Marcus Aurelius — Roman marble bust" />
        </div>
        <div class="about-bio">
          <div class="eyebrow" style="margin-bottom:18px">
            <span data-i18n="en">Marcus Aurelius · 121–180 CE · written in Greek</span>
            <span data-i18n="ru">Марк Аврелий · 121–180 гг. · на греческом</span>
          </div>
          <h1 class="about-bio-head">
            <span data-i18n="en">A quiet reader <em>for a restless book.</em></span>
            <span data-i18n="ru">Тихая читалка <em>для беспокойной книги.</em></span>
          </h1>
          <p>
            <span data-i18n="en">Marcus Aurelius wrote the Meditations in private, for himself, as a soldier and emperor.
            It was never meant for publication. It survived anyway — by manuscript, then by press,
            then by translation.</span>
            <span data-i18n="ru">Марк Аврелий писал «Размышления» приватно, для себя, будучи воином и императором.
            Они не предназначались для публикации — но уцелели: сперва в рукописи, затем в печати, затем в переводах.</span>
          </p>
          <p>
            <span data-i18n="en">This site publishes all twelve books in two public-domain translations — George Long (1862)
            in English and Семён Роговин (1914) in Russian — indexed, searchable, and linkable by passage.
            No commentary. No feeds. No login.</span>
            <span data-i18n="ru">Этот сайт публикует все двенадцать книг в двух переводах из public domain — Джорджа Лонга
            (1862) на английском и Семёна Роговина (1914) на русском — с индексом, поиском и прямой ссылкой
            на каждый пассаж. Без комментариев. Без ленты. Без логина.</span>
          </p>
          <p>
            <span data-i18n="en">The <a href="/fronto" style="color:var(--ochre-deep);border-bottom:1px solid currentColor">Letters to Fronto</a>
            section adds {letterCount} surviving letters between Marcus and his rhetoric teacher,
            in C. R. Haines's Loeb translation.</span>
            <span data-i18n="ru">Раздел <a href="/fronto" style="color:var(--ochre-deep);border-bottom:1px solid currentColor">Переписка с Фронтоном</a>
            добавляет {letterCount} сохранившихся писем между Марком и его учителем риторики
            в переводе К. Р. Хайнса (Loeb). Русского перевода писем пока нет.</span>
          </p>
        </div>
      </section>

      <section class="about-grid">
        <div class="about-cell">
          <div class="eyebrow">01</div>
          <h3><T en="Everything" ru="Всё целиком" /></h3>
          <p>
            <span data-i18n="en">All 487 passages of the Meditations in EN and RU, plus {letterCount} letters of
            the Fronto correspondence. George Long, Семён Роговин, and C. R. Haines translations.</span>
            <span data-i18n="ru">Все 487 пассажей Размышлений на двух языках, плюс {letterCount} писем переписки
            с Фронтоном. Переводы Джорджа Лонга, Семёна Роговина и К. Р. Хайнса.</span>
          </p>
        </div>
        <div class="about-cell">
          <div class="eyebrow">02</div>
          <h3>Permalink</h3>
          <p>
            <span data-i18n="en">Every passage has its own URL. Cite, share, or quote without losing the reference.</span>
            <span data-i18n="ru">У каждого пассажа свой URL. Цитируйте, делитесь, возвращайтесь — ссылка не сломается.</span>
          </p>
        </div>
        <div class="about-cell">
          <div class="eyebrow">03</div>
          <h3>Public domain</h3>
          <p>
            <span data-i18n="en">Every translation here is in the public domain. You can reuse them freely.</span>
            <span data-i18n="ru">Все переводы здесь — общественное достояние. Их можно свободно переиспользовать.</span>
          </p>
        </div>
      </section>

      <section class="about-translators">
        <div class="transl-col">
          <h4><T en="Meditations translators" ru="Переводчики Размышлений" /></h4>
          <div class="transl-entry">
            <span class="name">George Long</span>
            <span class="yr">1862 · public domain</span>
          </div>
          <div class="transl-entry">
            <span class="name">Семён Роговин</span>
            <span class="yr">1914 · public domain</span>
          </div>
        </div>
        <div class="transl-col">
          <h4><T en="Letters translator" ru="Переводчик писем" /></h4>
          <div class="transl-entry">
            <span class="name">C. R. Haines</span>
            <span class="yr">1919 · public domain</span>
          </div>
        </div>
      </section>
    </main>
  </Shell>
</Layout>
