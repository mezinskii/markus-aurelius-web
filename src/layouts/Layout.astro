---
import Analytics from "@vercel/analytics/astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "ru";
  /** Path on this language for hreflang alternate, e.g. "/book/3" or "/contents". */
  basePath?: string;
  /** JSON-LD objects to inject into <head>. Each becomes a separate <script>. */
  jsonLd?: Array<Record<string, unknown>>;
  /** Optional override for OG image absolute URL. */
  ogImage?: string;
}

const SITE_ORIGIN =
  (import.meta.env.PUBLIC_SITE_URL as string | undefined)?.replace(/\/$/, "") ||
  "https://readaurelius.org";

const {
  title = "Meditations — Marcus Aurelius",
  description = "The private notebook of a Roman emperor — twelve books, every passage a direct link.",
  lang = "en",
  basePath,
  jsonLd = [],
  ogImage,
} = Astro.props;

// Compute hreflang URLs
const path = basePath ?? Astro.url.pathname;
const stripped = path.replace(/^\/ru(?=\/|$)/, "") || "/";
const enUrl = SITE_ORIGIN + stripped;
const ruUrl = SITE_ORIGIN + (stripped === "/" ? "/ru" : "/ru" + stripped);
const canonicalUrl = lang === "ru" ? ruUrl : enUrl;

// Pick pre-rendered 1200×630 OG image for this route+lang.
function ogForRoute(p: string, l: "en" | "ru"): string {
  const s = p.replace(/^\/ru(?=\/|$)/, "") || "/";
  const suf = l === "ru" ? "-ru" : "-en";
  let slug = "home";
  if (s === "/contents") slug = "contents";
  else if (s === "/about") slug = "about";
  else if (s === "/sayings") slug = "sayings";
  else if (s === "/fronto" || s.startsWith("/fronto/")) slug = "fronto";
  return `${SITE_ORIGIN}/og/${slug}${suf}.png`;
}
const ogImageUrl = ogImage ?? ogForRoute(stripped, lang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* hreflang alternates */}
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="ru" href={ruUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    {/* Crawler hints */}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Read Aurelius" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === "ru" ? "ru_RU" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD structured data */}
    {jsonLd.map(obj => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="app">
      <slot />
    </div>
    <script is:inline>
      // Restore theme from localStorage to avoid flash
      try {
        const t = localStorage.getItem("theme");
        if (t === "dark")
          document.documentElement.setAttribute("data-theme", "dark");
      } catch {}
    </script>
    <Analytics />
  </body>
</html>
