---
import Layout from '../../layouts/Layout.astro';
import Shell from '../Shell';
import { BOOK_META, romanize, passageWord, UI, type Lang } from '../../lib/ui';
import { breadcrumbsJsonLd, meditationsBookJsonLd, pageUrl } from '../../lib/seo';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = UI[lang];

const langPrefix = lang === 'ru' ? '/ru' : '';
const pathname = `${langPrefix}/contents`;

const title = lang === 'ru'
  ? 'Оглавление «Размышлений» Марка Аврелия — все 12 книг'
  : 'Contents — Meditations of Marcus Aurelius (All 12 Books)';
const description = lang === 'ru'
  ? 'Оглавление «Размышлений» Марка Аврелия: двенадцать книг, 487 пассажей в переводе Семёна Роговина (1914). Public domain.'
  : 'Contents of Marcus Aurelius\'s Meditations: twelve books, 487 passages in the George Long translation (1862). Public domain.';

const url = pageUrl(lang, '/contents');
const jsonLd = [
  meditationsBookJsonLd(lang),
  breadcrumbsJsonLd([
    { name: lang === 'ru' ? 'Главная' : 'Home', url: pageUrl(lang, '/') },
    { name: lang === 'ru' ? 'Оглавление' : 'Contents', url },
  ]),
];
---
<Layout title={title} description={description} lang={lang} basePath="/contents" jsonLd={jsonLd}>
  <Shell route="contents" lang={lang} pathname={pathname} client:load>
    <main class="wrap">
      <div class="crumbs">
        <a href={langPrefix || '/'}>{t.read}</a>
        <span class="sep">/</span>
        <span>{t.contents}</span>
      </div>

      <div class="book-head">
        <div class="book-head-num">XII</div>
        <div class="book-head-meta">
          <div class="book-head-eyebrow">{t.home_eyebrow}</div>
          <h1 class="book-head-title">
            {lang === 'ru'
              ? <>Оглавление <em>«Размышлений»</em></>
              : <>Contents of the <em>Meditations</em></>}
          </h1>
          <p class="book-head-note">
            {lang === 'ru'
              ? <>Полное оглавление «Размышлений» Марка Аврелия — двенадцать книг, 487 пассажей
                в переводе Семёна Роговина (1914). Каждая книга — отдельная записная книжка:
                можно читать по порядку или открывать ту, что ближе сегодня. Тексты в общественном достоянии.</>
              : <>The complete contents of Marcus Aurelius's <em>Meditations</em> — twelve books,
                487 passages in the public-domain George Long translation (1862). Each book is its own
                notebook: read them in order, or open whichever feels closest today.</>}
          </p>
        </div>
      </div>

      <div class="books-grid">
        {BOOK_META.map(b => (
          <a href={`${langPrefix}/book/${b.n}`} class="book-tile">
            <div class="book-tile-num">{romanize(b.n)}</div>
            <div class="book-tile-label">{lang === 'ru' ? 'Книга' : 'Book'} {b.n}</div>
            <p class="book-tile-quote">«{b.quote[lang]}»</p>
            <div class="book-tile-count">{b.count} {passageWord(b.count, lang)}</div>
          </a>
        ))}
      </div>
    </main>
  </Shell>
</Layout>
