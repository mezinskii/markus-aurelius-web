---
import Layout from '../../layouts/Layout.astro';
import Shell from '../Shell';
import { getAllSayings } from '../../lib/sanity';
import { romanize, UI, type Lang } from '../../lib/ui';
import { renderWithFootnotes } from '../../lib/footnotes';
import { sayingJsonLd, breadcrumbsJsonLd, marcusAureliusPerson, pageUrl } from '../../lib/seo';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = UI[lang];

const sayings = await getAllSayings();
const langPrefix = lang === 'ru' ? '/ru' : '';
const pathname = `${langPrefix}/sayings`;

const title = lang === 'ru'
  ? `Изречения Марка Аврелия — ${sayings.length} фрагментов из Диона и Historia Augusta`
  : `Sayings of Marcus Aurelius — ${sayings.length} Fragments from Dio and the Historia Augusta`;
const description = lang === 'ru'
  ? `${sayings.length} коротких изречений Марка Аврелия, сохранённых Дионом Кассием, Historia Augusta и другими — не из «Размышлений». Перевод C. R. Haines (Loeb, 1916), public domain.`
  : `${sayings.length} short sayings of Marcus Aurelius preserved by Dio Cassius, the Historia Augusta and others — not from the Meditations. C. R. Haines translation (Loeb, 1916), public domain.`;

const url = pageUrl(lang, '/sayings');
const cleanText = (s: string) => s.replace(/\{\{fn:\d+\}\}|\[\d+\]/g, '');
const jsonLd = [
  marcusAureliusPerson(),
  breadcrumbsJsonLd([
    { name: lang === 'ru' ? 'Главная' : 'Home', url: pageUrl(lang, '/') },
    { name: lang === 'ru' ? 'Изречения' : 'Sayings', url },
  ]),
  ...sayings.slice(0, 30).map(s => sayingJsonLd({
    text: cleanText(s.text),
    source: s.source,
    url: url + `#s${s.order}`,
    order: s.order,
  })),
];
---
<Layout title={title} description={description} lang={lang} basePath="/sayings" jsonLd={jsonLd}>
  <Shell route="sayings" lang={lang} pathname={pathname} client:load>
    <main class="wrap">

      <div class="crumbs">
        <a href={langPrefix || '/'}>{t.read}</a>
        <span class="sep">/</span>
        <span>{t.sayings}</span>
      </div>

      <div class="book-head" style="grid-template-columns:auto 1fr">
        <div class="book-head-num" style="font-size:clamp(48px,7vw,120px)">{romanize(sayings.length)}</div>
        <div class="book-head-meta">
          <div class="book-head-eyebrow">
            {lang === 'ru'
              ? <>Марк Аврелий · записано древними биографами · не из <em>Размышлений</em></>
              : <>Marcus Aurelius · recorded by ancient biographers · not from the <em>Meditations</em></>}
          </div>
          <h1 class="book-head-title">
            {lang === 'ru'
              ? <>Цитаты и <em>изречения</em></>
              : <>Quotes and <em>Sayings</em></>}
          </h1>
          <p class="book-head-note">
            {lang === 'ru'
              ? <>{sayings.length} коротких цитат и изречений Марка Аврелия, не вошедших в «Размышления»,
                — сохранённых Дионом Кассием, <em>Historia Augusta</em> и другими: реплики, подслушанные
                в совете, у одра болезни, на поле боя. Собраны в приложении к Loeb (Хайнс, 1916). Русского
                перевода пока нет — тексты на английском.</>
              : <>{sayings.length} short quotes and sayings of Marcus Aurelius, outside the <em>Meditations</em>,
                preserved by Dio Cassius, the <em>Historia Augusta</em> and others — remarks overheard at council,
                the sickbed, the battlefield. Collected in the Loeb Appendix (Haines, 1916).</>}
          </p>
        </div>
      </div>

      <div class="home-meta" style="margin-bottom:56px;padding-top:24px;border-top:1px solid var(--rule)">
        <div>{lang === 'ru' ? 'Число' : 'Count'}<strong>{sayings.length}</strong></div>
        <div>{lang === 'ru' ? 'Переводчик' : 'Translator'}<strong>C. R. Haines, 1916</strong></div>
        <div>
          {lang === 'ru' ? 'Источники' : 'Sources'}
          <strong>{lang === 'ru' ? 'Дион · Капитолин' : 'Dio · Capitolinus'}</strong>
        </div>
        <div>{lang === 'ru' ? 'Права' : 'Rights'}<strong>Public domain</strong></div>
      </div>

      <div style="max-width:var(--measure);margin-bottom:56px">
        <p style="font-family:var(--serif);font-size:17px;line-height:1.65;color:var(--text-soft);margin:0 0 1em">
          {lang === 'ru'
            ? <>Самые известные цитаты Марка Аврелия — те, что он писал сам себе ночами, — собраны
              в <em>Размышлениях</em>. А это другое: апокрифические изречения, дошедшие как анекдот,
              подслушанные придворным, переписанные в историю, запомненные биографом. Кратко, неровно,
              иногда сомнительно — но ближе к живому голосу в комнате.</>
            : <>The most famous quotes of Marcus Aurelius — the ones he wrote to himself at night —
              are collected in the <em>Meditations</em>. These are something else: apocryphal sayings
              preserved as anecdote, overheard by a courtier, copied into a history, remembered by a
              biographer. Brief, uneven, sometimes doubtful — but closer to a voice in a room.</>}
        </p>
      </div>

      <div class="books-section-head">
        <h2>
          {lang === 'ru' ? `Все ${sayings.length} изречений` : `All ${sayings.length} sayings`}
          <em style="font-size:18px;margin-left:10px">{lang === 'ru' ? 'по порядку' : 'in order'}</em>
        </h2>
      </div>

      <div class="sayings-list">
        {sayings.map(s => (
          <article class="saying-card" id={`s${s.order}`}>
            <div class="saying-card-num">{String(s.order).padStart(2, '0')}</div>
            <div class="saying-card-body">
              <p class="saying-card-text" set:html={renderWithFootnotes(s.text, s.footnotes)} />
              <div class="saying-card-meta">
                <span class="saying-card-source">— {s.source}</span>
                <a class="saying-card-anchor" href={`#s${s.order}`} aria-label={`Permalink to saying ${s.order}`}>#</a>
              </div>
              {s.footnotes && s.footnotes.length > 0 && (
                <div class="saying-card-footnotes">
                  {s.footnotes.map(fn => (
                    <div class="saying-card-fn">
                      <span class="saying-card-fn-key">{fn.key}</span>
                      <span>{fn.text}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>

      <div style="margin-top:56px;padding-top:32px;border-top:1px solid var(--rule);font-family:var(--sans);font-size:13px;color:var(--text-soft)">
        <a href={langPrefix || '/'} style="border-bottom:1px solid var(--rule)">
          {lang === 'ru' ? '← Назад к Размышлениям' : '← Back to Meditations'}
        </a>
      </div>
    </main>
  </Shell>
</Layout>

<style>
.sayings-list { display: flex; flex-direction: column; gap: 0; }
.saying-card {
  display: grid;
  grid-template-columns: 88px 1fr;
  gap: 28px;
  padding: 32px 0;
  border-top: 1px solid var(--rule);
  align-items: baseline;
  scroll-margin-top: 80px;
}
.saying-card:last-of-type { border-bottom: 1px solid var(--rule); }
.saying-card:target { background: color-mix(in oklch, var(--ochre-wash) 35%, transparent); }
.saying-card-num {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.14em;
  color: var(--rubric);
  padding-top: 6px;
}
.saying-card-text {
  font-family: var(--serif);
  font-size: 18px;
  line-height: 1.65;
  color: var(--text);
  margin: 0 0 14px;
  text-wrap: pretty;
}
.saying-card-meta { display: flex; align-items: baseline; gap: 10px; }
.saying-card-source {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-mute);
}
.saying-card-anchor {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-mute);
  opacity: 0;
  transition: opacity .18s;
  border-bottom: 0 !important;
}
.saying-card:hover .saying-card-anchor,
.saying-card:target .saying-card-anchor { opacity: 1; color: var(--ochre-deep); }
.saying-card-footnotes { margin-top: 18px; padding-top: 14px; border-top: 1px dashed var(--rule); }
.saying-card-fn {
  display: flex;
  gap: 10px;
  font-family: var(--serif);
  font-size: 13.5px;
  line-height: 1.5;
  color: var(--text-soft);
  margin-bottom: 6px;
}
.saying-card-fn-key {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--rubric);
  flex-shrink: 0;
  padding-top: 3px;
  min-width: 14px;
}

@media (max-width: 720px) {
  .saying-card { grid-template-columns: 56px 1fr; gap: 16px; padding: 24px 0; }
  .saying-card-text { font-size: 16.5px; }
}
</style>
